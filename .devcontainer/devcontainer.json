{
  "name": "next-edge",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [3000, 6006],
  "postCreateCommand": "bash -lc 'corepack enable && corepack prepare pnpm@10.12.1 --activate && pnpm install'",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true
      },
      "extensions": [
        "biomejs.biome",
        "dbaeumer.vscode-eslint",
        "ms-playwright.playwright"
      ]
    }
  }
}
